# Copy this file to .env and fill values locally. Never commit .env.

# OpenAI: live AI planner/status/postmortem. Fallbacks work without this in demo mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_POSTMORTEM_MODEL=gpt-4.1

# Slack app credentials. Required for /incident and button interactions.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Atlassian Jira Cloud. Jira is the source of truth when DEMO_MODE=false.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=OPS

# Atlassian Confluence Cloud. Can share email/token with Jira if permissions allow.
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_ID=

# PagerDuty Events API v2 integration/routing key.
PAGERDUTY_ROUTING_KEY=

# Upstash Redis REST credentials. Without these, local in-memory state is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# For Slack local testing, replace localhost with a public HTTPS tunnel URL.
APP_BASE_URL=http://localhost:8000
DEMO_MODE=true
